# PlantCare Backend — Environment Variables
# Copy this file to .env and fill in your values before running.
# NEVER commit .env to version control.

# JWT secret — use a long random string in production
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_STRING

# Fernet key — run: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Used for AES-256 encryption of sensitive data at rest (ITEL 305 IA requirement)
FERNET_KEY=GENERATE_WITH_COMMAND_ABOVE

# Database path
DB_PATH=plantcare.db

# ML model path (run train_model.py first)
ML_MODEL_PATH=plant_ml_models.pkl

# EmailJS credentials (for password reset emails — set in frontend)
# EMAILJS_SERVICE_ID=your_service_id
# EMAILJS_TEMPLATE_ID=your_template_id
# EMAILJS_PUBLIC_KEY=your_public_key

# VAPID Keys for Web Push Notifications (optional but recommended for production)
# Generate with: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print('PUBLIC:', v.public_key); print('PRIVATE:', v.private_key)"
# Or use: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=your-email@example.com

# AWS EC2 Deployment
# Set to your EC2 public IP or domain when deploying
# Example: http://ec2-12-34-56-78.compute-1.amazonaws.com
# BACKEND_HOST=0.0.0.0
# BACKEND_PORT=8000
